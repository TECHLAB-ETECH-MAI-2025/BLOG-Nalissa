{% extends 'base.html.twig' %}

{% block title %}✏️ Modifier Catégorie{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="card shadow p-4">
        <h1 class="mb-4 text-primary">✏️ Modifier la catégorie</h1>

        {{ include('categorie/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

        <div class="d-flex justify-content-between mt-4">
