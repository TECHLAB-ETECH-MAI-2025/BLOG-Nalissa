{% extends 'base.html.twig' %}

{% block title %}👁️ Détails de la Catégorie{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="card shadow p-4">
        <h1 class="mb-4 text-primary">👁️ Détails de la catégorie</h1>

        <table class="table table-bordered">
            <tbody>
                <tr>
                    <th>ID</th>
                    <td>{{ categorie.id }}</td>
                </tr>
                <tr>
                    <th>Titre</th>
                    <td>{{ categorie.title }}</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>{{ categorie.description }}</td>
                </tr>
            </tbody>
        </table>

        <div class="d-flex justify-content-between mt-4">
            <a href="{{ path('app_categorie_index') }}" class="btn btn-outline-primary">⬅️ Retour à la liste</a>
            <a href="{{ path('app_categorie_edit', {'id': categorie.id}) }}" class="btn btn-outline-secondary">✏️ Modifier</a>
            {{ include('categorie/_delete_form.html.twig') }}
        </div>
    </div>
</div>
{% endblock %}
