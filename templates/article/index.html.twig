{% extends 'base.html.twig' %}

{% block title %}Liste des articles{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Liste des Articles</h1>
        <a href="{{ path('app_article_new') }}" class="btn btn-success">➕ Créer un article</a>
    </div>

    {% if articles is not empty %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for article in articles %}
                <div class="col">
                    <div class="card h-100 shadow-sm">
                                {% if article.image %}

                        <img src="{{ asset(article.image) }}" class="card-img-top" alt="Image de l'article">
                         {% else %}
                                 <p class="text-muted">Aucune image</p>
                                {% endif %}
                        <div class="card-body">
                            <h5 class="card-title">{{ article.title }}</h5>
                            <p class="card-text">{{ article.description|slice(0, 150) ~ '...' }}</p>

                            {% for cat in article.categorie %}
                                <span class="badge bg-primary me-1">{{ cat.title }}</span>
                            {% endfor %}
                        </div>
                        <div class="card-footer d-flex justify-content-between">
                            <a href="{{ path('app_article_show', {'id': article.id}) }}" class="btn btn-outline-primary btn-sm">🔍 Voir</a>
                            <a href="{{ path('app_article_edit', {'id': article.id}) }}" class="btn btn-outline-secondary btn-sm">✏️ Modifier</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-info mt-4">
            Aucun article n’a été trouvé. Créez-en un dès maintenant !
        </div>
    {% endif %}
</div>
{% endblock %}
