{% extends 'base.html.twig' %}

{% block title %}Article index{% endblock %}

{% block body %}
    <h1>Article </h1>

    
        {% for article in articles %}
           <div class="card" style="width: 25rem;">
                    <img src="{{ asset(article.image) }}" class="card-img-top img-fluid" alt="Image de l'article" style="max-width: 300px;">
                <div class="card-body">
                    <h5 class="card-title">{{ article.title }}</h5>
                    <p class="card-text">{{ article.description }}</p>
                </div>
                   {% for cat in article.categorie %}
                    <span class="badge bg-primary">{{ cat.title }}</span>
                   {% endfor %}

                 <a href="{{ path('app_article_show', {'id': article.id}) }}">show</a>
                    <a href="{{ path('app_article_edit', {'id': article.id}) }}">edit</a>
           </div>

                   
              
        {% else %}
           
        {% endfor %}
     

    <a href="{{ path('app_article_new') }}">Create new</a>
{% endblock %}
