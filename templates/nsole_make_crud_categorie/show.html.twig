{% extends 'base.html.twig' %}

{% block title %}Article{% endblock %}

{% block body %}
    <h1>Article</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ article.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ article.title }}</td>
            </tr>
            <tr>
                <th>Decription</th>
                <td>{{ article.decription }}</td>
            </tr>
            <tr>
                <th>Image</th>
                <td>{{ article.image }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_nsole_make_crud_categorie_index') }}">back to list</a>

    <a href="{{ path('app_nsole_make_crud_categorie_edit', {'id': article.id}) }}">edit</a>

    {{ include('nsole_make_crud_categorie/_delete_form.html.twig') }}
{% endblock %}
